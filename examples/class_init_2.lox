class Calculator {
	init(value1, value2) {
		this.value1 = value1;
		this.value2 = value2;
	}
	sum() {
		return this.value1 + this.value2;
	}
	sub() {
		return this.value1 - this.value2;
	}
	div() {
		return this.value1 / this.value2;
	}
	mul() {
		return this.value1 * this.value2;
	}
}

var calculator = Calculator(20, 10);

print calculator.sum();
print calculator.sub();
print calculator.div();
print calculator.mul();
